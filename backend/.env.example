# ==============================
# CivicSense Backend - Environment Variables
# Copy this to .env and fill in real values
# ==============================

# Server Configuration
NODE_ENV=production
PORT=5000

# MongoDB Connection (MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/civicsense

# Frontend URL (for CORS - comma-separated if multiple)
FRONTEND_URL=https://your-app.onrender.com

# Frontend Static Files Path (for Render monolith deployment)
# Only needed if serving frontend from backend
FRONTEND_STATIC_DIR=/opt/render/project/src/frontend/public

# Upload Directories
UPLOADS_DIR=/opt/render/project/src/uploads
TEMP_UPLOAD_DIR=/opt/render/project/src/uploads/tmp

# Email Settings (Gmail SMTP)
ADMIN_EMAIL=your-admin@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Twilio SMS Settings
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_PHONE=+1xxxxxxxxxx

# JWT Configuration (use a long random string in production)
JWT_SECRET=replace-with-a-very-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key
